# Sao chép thành .env (không commit). Giá trị dưới đây hợp cho Postgres chạy Docker (make db-up).
APP_ENV=dev
HTTP_ADDR=:8080

# Database
DATABASE_URL=postgres://postgres:dev@localhost:55432/maymac?sslmode=disable
DB_MAX_CONNS=10
DB_MIN_CONNS=0
DB_MAX_CONN_LIFETIME=1h
DB_STATEMENT_TIMEOUT=5s
DB_IDLE_IN_TRANSACTION_SESSION_TIMEOUT=10s

# HTTP timeouts (định dạng Go duration)
HTTP_READ_TIMEOUT=10s
HTTP_WRITE_TIMEOUT=15s
HTTP_IDLE_TIMEOUT=60s
HTTP_SHUTDOWN_TIMEOUT=10s
